{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public profile information for a user.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "coverURL": { "type": "string" },
        "bio": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "email", "createdAt"]
    },
    "Post": {
      "title": "Social Media Post",
      "description": "A post containing text and optional media.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "mediaURL": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["image", "video", "none"] },
        "likesCount": { "type": "integer" },
        "commentsCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "content", "createdAt"]
    },
    "Comment": {
      "title": "Post Comment",
      "description": "A comment on a post.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "text", "createdAt"]
    },
    "Chat": {
      "title": "Chat Metadata",
      "description": "Metadata for a 1-on-1 or group chat.",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message in a chat.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "mediaURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "text", "createdAt"]
    },
    "Notification": {
      "title": "User Notification",
      "description": "Alert for user interactions.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["like", "comment", "follow", "message"] },
        "fromId": { "type": "string" },
        "fromName": { "type": "string" },
        "postId": { "type": "string" },
        "text": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "fromId", "createdAt", "read"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/users/{userId}/following/{followingId}": {
      "schema": { "type": "object", "properties": { "at": { "type": "string", "format": "date-time" } } },
      "description": "Users followed by this user."
    },
    "/users/{userId}/followers/{followerId}": {
      "schema": { "type": "object", "properties": { "at": { "type": "string", "format": "date-time" } } },
      "description": "Users following this user."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Global posts feed."
    },
    "/posts/{postId}/likes/{userId}": {
      "schema": { "type": "object", "properties": { "at": { "type": "string", "format": "date-time" } } },
      "description": "Likes on a post."
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a post."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Direct message thread metadata."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Individual chat messages."
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User-specific notifications."
    }
  }
}
